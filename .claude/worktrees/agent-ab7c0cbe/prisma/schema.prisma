generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  VIEWER
}

enum InstanceStatus {
  INITIALIZING
  QR_PENDING
  CONNECTED
  DISCONNECTED
  BANNED
  PAUSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  QUEUED
  SCHEDULED
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessageType {
  text
  image
  video
  audio
  document
  sticker
  location
  contact
  poll
  reaction
  list
  buttons
  template
}

enum DeliveryStatus {
  PENDING
  SUCCESS
  FAILED
  DEAD_LETTER
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  TRANSFERRED
}

model Tenant {
  id                    String        @id @default(cuid())
  name                  String
  slug                  String        @unique
  plan                  String        @default("enterprise")
  instanceLimit         Int           @default(10)
  messagesPerMinute     Int           @default(20)
  retentionDays         Int           @default(30)
  messagesThisMonth     Int           @default(0)
  users                 User[]
  apiKeys               ApiKey[]
  instances             Instance[]
  contacts              Contact[]
  conversations         Conversation[]
  messages              Message[]
  templates             MessageTemplate[]
  auditLogs             AuditLog[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model User {
  id                    String        @id @default(cuid())
  tenantId              String
  email                 String
  name                  String
  role                  Role
  passwordHash          String?
  oauthProvider         String?
  oauthSubject          String?
  samlSubject           String?
  twoFactorEnabled      Boolean       @default(false)
  totpSecret            String?
  backupCodes           String[]      @default([])
  lastLoginAt           DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  tenant                Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
}

model ApiKey {
  id                    String        @id @default(cuid())
  tenantId              String
  name                  String
  keyHash               String
  scopes                String[]
  expiresAt             DateTime?
  lastUsedAt            DateTime?
  revokedAt             DateTime?
  createdAt             DateTime      @default(now())
  tenant                Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, keyHash])
}

model Instance {
  id                    String         @id @default(cuid())
  tenantId              String
  name                  String
  phoneNumber           String?
  avatarUrl             String?
  status                InstanceStatus @default(INITIALIZING)
  authDirectory         String
  sessionDbPath         String
  proxyUrl              String?
  workerHeartbeatAt     DateTime?
  reconnectAttempts     Int            @default(0)
  riskScore             Int            @default(0)
  lastError             String?
  lastActivityAt        DateTime?
  connectedAt           DateTime?
  pausedAt              DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  tenant                Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usage                 InstanceUsage?
  messages              Message[]
  webhookEndpoint       WebhookEndpoint?
  contacts              Contact[]
  conversations         Conversation[]

  @@index([tenantId, status])
}

model InstanceUsage {
  id                    String        @id @default(cuid())
  instanceId            String        @unique
  messagesSent          Int           @default(0)
  messagesReceived      Int           @default(0)
  errors                Int           @default(0)
  uptimeSeconds         Int           @default(0)
  lastResetAt           DateTime      @default(now())
  instance              Instance      @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model Message {
  id                    String            @id @default(cuid())
  tenantId              String
  instanceId            String
  remoteJid             String
  externalMessageId     String?
  direction             MessageDirection
  type                  MessageType
  status                MessageStatus
  payload               Json
  traceId               String?
  errorMessage          String?
  scheduledAt           DateTime?
  sentAt                DateTime?
  deliveredAt           DateTime?
  readAt                DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  tenant                Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instance              Instance          @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId, createdAt])
  @@index([tenantId, status])
}

model WebhookEndpoint {
  id                    String           @id @default(cuid())
  instanceId            String           @unique
  url                   String
  secretEncrypted       String
  headers               Json
  subscribedEvents      String[]
  isActive              Boolean          @default(true)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  instance              Instance         @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  deliveries            WebhookDelivery[]
}

model WebhookDelivery {
  id                    String          @id @default(cuid())
  webhookEndpointId     String
  eventType             String
  payload               Json
  status                DeliveryStatus  @default(PENDING)
  attempt               Int             @default(0)
  httpStatus            Int?
  responseBody          String?
  nextRetryAt           DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  webhookEndpoint       WebhookEndpoint @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)

  @@index([webhookEndpointId, status])
}

model Contact {
  id                    String         @id @default(cuid())
  tenantId              String
  instanceId            String
  phoneNumber           String
  displayName           String?
  fields                Json?
  notes                 String?
  isBlacklisted         Boolean        @default(false)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  tenant                Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instance              Instance       @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  conversations         Conversation[]

  @@unique([instanceId, phoneNumber])
}

model Conversation {
  id                    String             @id @default(cuid())
  tenantId              String
  instanceId            String
  contactId             String
  assignedToUserId      String?
  status                ConversationStatus @default(OPEN)
  tags                  String[]           @default([])
  slaDeadlineAt         DateTime?
  lastMessageAt         DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instance              Instance           @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  contact               Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model MessageTemplate {
  id                    String        @id @default(cuid())
  tenantId              String
  name                  String
  body                  String
  variables             String[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  tenant                Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
}

model AuditLog {
  id                    String        @id @default(cuid())
  tenantId              String
  actorType             String
  actorId               String
  action                String
  ipAddress             String
  targetType            String
  targetId              String
  payload               Json
  signature             String
  createdAt             DateTime      @default(now())
  tenant                Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}
