{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infra/docker/worker.Dockerfile",
    "watchPatterns": [
      "apps/worker/**",
      "apps/api/prisma/**",
      "prisma/**",
      "packages/types/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.base.json",
      "infra/docker/worker.Dockerfile"
    ]
  },
  "deploy": {
    "startCommand": "node apps/worker/dist/index.js",
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 10
  }
}
